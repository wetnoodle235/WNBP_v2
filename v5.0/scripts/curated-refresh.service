[Unit]
Description=SportStock V5.0 - Recurring Curated Refresh (auto)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/derek/Documents/stock/v5.0
ExecStart=/home/derek/Documents/stock/.venv/bin/python3 scripts/recurring_curated_refresh.py --mode auto
Environment=PATH=/home/derek/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=HOME=/home/derek
EnvironmentFile=-/home/derek/Documents/stock/v5.0/.env
StandardOutput=append:/home/derek/Documents/stock/v5.0/logs/curated_refresh.log
StandardError=append:/home/derek/Documents/stock/v5.0/logs/curated_refresh.log
TimeoutStartSec=3600

[Install]
WantedBy=default.target
