{
  "name": "@stock/importers",
  "version": "5.0.0",
  "type": "module",
  "private": true,
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "import": "tsx src/cli.ts",
    "import:espn": "tsx src/cli.ts --provider=espn",
    "import:oddsapi": "tsx src/cli.ts --provider=oddsapi",
    "import:odds": "tsx src/cli.ts --provider=odds",
    "live": "tsx src/live/runner.ts",
    "import:nbastats": "tsx src/cli.ts --provider=nbastats",
    "import:nflfastr": "tsx src/cli.ts --provider=nflfastr",
    "import:apisports": "tsx src/cli.ts --provider=apisports",
    "import:cfbdata": "tsx src/cli.ts --provider=cfbdata",
    "import:cfbdata:2020-2026": "tsx src/cli.ts --provider=cfbdata --sports=ncaaf --seasons=2020,2021,2022,2023,2024,2025,2026",
    "import:cfbdata:2020-2026:dry": "tsx src/cli.ts --provider=cfbdata --sports=ncaaf --seasons=2020,2021,2022,2023,2024,2025,2026 --dry-run",
    "import:statsbomb": "tsx src/cli.ts --provider=statsbomb",
    "import:understat": "tsx src/cli.ts --provider=understat",
    "import:openf1": "tsx src/cli.ts --provider=openf1",
    "import:ergast": "tsx src/cli.ts --provider=ergast",
    "import:tennisabstract": "tsx src/cli.ts --provider=tennisabstract",
    "import:ufcstats": "tsx src/cli.ts --provider=ufcstats",
    "import:lahman": "tsx src/cli.ts --provider=lahman",
    "import:nhl": "tsx src/cli.ts --provider=nhl",
    "import:clearsports": "tsx src/cli.ts --provider=clearsports",
    "import:pandascore": "tsx src/cli.ts --provider=pandascore",
    "import:opendota": "tsx src/cli.ts --provider=opendota",
    "import:weather": "tsx src/cli.ts --provider=weather",
    "import:oracleselixir": "tsx src/cli.ts --provider=oracleselixir",
    "import:all": "tsx src/cli.ts --all",
    "list": "tsx src/cli.ts --list",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "node-html-parser": "^6.1.0",
    "csv-parse": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "eslint": "^9.0.0"
  }
}
