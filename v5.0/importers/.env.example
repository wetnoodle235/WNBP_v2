# V5.0 Environment Variables
# Copy to .env and fill in your values

# === API Keys (required for key-gated providers) ===
ODDSAPI_KEY=
API_SPORTS_KEY=
CFB_DATA_KEY=
VISUAL_CROSSING_KEY=
CLEARSPORTS_KEY=
PANDASCORE_KEY=

# === Data Directory ===
DATA_DIR=../data

# === Rate Limiting Overrides (ms between requests) ===
# ESPN_DELAY_MS=500
# NBASTATS_DELAY_MS=1200
# APISPORTS_DELAY_MS=6500
# ODDSAPI_DELAY_MS=1000

# === Logging ===
LOG_LEVEL=info
